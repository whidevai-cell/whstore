@model IEnumerable<whstore.Models.ProductModel>

@{
    ViewData["Title"] = "Halal OS - Web Store";
}

<style>
    body {
        background-color: #000;
        color: white;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    /* প্রিমিয়াম কার্ড ডিজাইন */
    .product-card {
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        cursor: pointer;
        border-radius: 12px !important;
        border: 1px solid #222 !important;
        background-color: #0a0a0a !important;
        overflow: hidden;
        position: relative;
    }

    .product-card:hover {
        transform: translateY(-10px);
        background-color: #111 !important;
        border-color: #0dcaf0 !important;
        box-shadow: 0 0 20px rgba(13, 202, 240, 0.15) !important;
    }

    .card-img-container {
        background: #fff;
        padding: 10px;
        height: 180px;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
    }

    .card-img-top {
        max-height: 100%;
        width: auto;
        object-fit: contain;
    }

    .btn-xs {
        padding: 0.4rem 0.6rem;
        font-size: 0.75rem;
        border-radius: 6px;
        font-weight: 600;
        letter-spacing: 0.3px;
    }

    /* Hot Product Badge */
    .hot-badge {
        position: absolute;
        top: 10px;
        left: 10px;
        background: #ff4757;
        color: white;
        font-size: 9px;
        font-weight: bold;
        padding: 3px 10px;
        border-radius: 20px;
        z-index: 10;
        text-transform: uppercase;
        box-shadow: 0 0 10px rgba(255, 71, 87, 0.5);
    }

    .badge-source {
        background: linear-gradient(45deg, #0dcaf0, #007bff);
        color: white;
        font-size: 9px;
        padding: 5px 12px;
        border-radius: 0 0 0 15px;
        font-weight: 800;
        z-index: 2;
    }

    .price-tag {
        color: #0dcaf0;
        font-family: 'Orbitron', sans-serif;
    }

    .old-price {
        color: #666;
        text-decoration: line-through;
        font-size: 0.8rem;
        margin-left: 5px;
    }

    .store-info {
        font-size: 10px;
        color: #888;
        margin-bottom: 5px;
    }

    .border-dashed {
        border-style: dashed !important;
        border-width: 2px !important;
    }

    .tracking-wider {
        letter-spacing: 2px;
    }
</style>

<div class="container-fluid bg-black text-white p-4 min-vh-100">
    @* --- Header Section --- *@
    <div class="d-flex justify-content-between align-items-center mb-5 pb-3 border-bottom border-dark">
        <div>
            <h3 class="fw-bold m-0 text-uppercase tracking-wider text-info">
                <i class="bi bi-terminal-fill me-2"></i> WH A STORE <span class="text-white opacity-50">PRO</span>
            </h3>
            <small class="text-muted text-uppercase" style="font-size: 10px;">Rajshahi Tech Hub | Hybrid V2.5.0</small>
        </div>
        <div class="d-flex gap-3 align-items-center">
            <div class="text-end d-none d-md-block">
                @if (ViewBag.CloudStatus == "OFFLINE")
                {
                    <div class="small text-warning fw-bold" style="font-size: 10px;"><i class="bi bi-cloud-slash-fill me-1"></i> CLOUD OFFLINE</div>
                }
                else
                {
                    <div class="small text-success fw-bold" style="font-size: 10px;"><i class="bi bi-shield-check me-1"></i> CLOUD ONLINE</div>
                }
                <div class="text-muted small" style="font-size: 11px;">Active Nodes: @(Model?.Count() ?? 0)</div>
            </div>
            <button class="btn btn-outline-info btn-sm px-4 rounded-pill shadow-sm" onclick="location.reload()">
                <i class="bi bi-arrow-repeat me-1"></i> REFRESH
            </button>
        </div>
    </div>

    @* --- Product Grid Section --- *@
    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            @foreach (var item in Model)
            {
                <div class="col-xl-2 col-lg-3 col-md-4 col-sm-6">
                    <div class="card h-100 product-card border-0">

                        @if (item.IsHotProduct)
                        {
                            <div class="hot-badge"><i class="bi bi-fire"></i> HOT</div>
                        }

                        <div class="card-img-container">
                            <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "https://via.placeholder.com/300?text=No+Image" : item.ImageUrl)"
                                 class="card-img-top"
                                 alt="product"
                                 onerror="this.onerror=null;this.src='https://via.placeholder.com/300?text=Image+Error';">

                            <span class="badge badge-source position-absolute top-0 end-0 text-uppercase">
                                @(string.IsNullOrEmpty(item.StoreName) ? "GLOBAL" : item.StoreName)
                            </span>
                        </div>

                        <div class="card-body p-3 d-flex flex-column">
                            <div class="store-info text-uppercase">
                                <i class="bi bi-box-seam me-1"></i> @(item.Category ?? "GADGET")
                            </div>

                            <p class="text-truncate d-block mb-2 fw-light" title="@item.Title" style="font-size: 0.8rem; color: #ccc; height: 1.2rem;">
                                @item.Title
                            </p>

                            <div class="mb-3">
                                <div class="d-flex align-items-baseline">
                                    <h5 class="price-tag fw-bold m-0">৳ @item.Price</h5>
                                    @if (!string.IsNullOrEmpty(item.OriginalPrice))
                                    {
                                        <span class="old-price">৳@item.OriginalPrice</span>
                                    }
                                </div>
                                <div style="font-size: 9px; color: #0dcaf0;" class="mt-1">
                                    <i class="bi bi-truck me-1"></i> @(item.ShippingCost == "0" ? "Free Delivery" : item.ShippingCost)
                                </div>
                            </div>

                            <div class="mt-auto d-grid gap-2">
                                <a href="@item.AffiliateLink" target="_blank" class="btn btn-xs btn-info fw-bold text-dark shadow-sm">
                                    <i class="bi bi-cart-check me-1"></i> BUY NOW
                                </a>
                                <div class="d-flex gap-2">
                                    <button class="btn btn-xs btn-outline-secondary w-100 text-muted border-secondary">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                    <button class="btn btn-xs btn-outline-danger w-100 border-danger opacity-75">
                                        <i class="bi bi-heart"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <div class="py-5 rounded-4 border border-secondary border-dashed" style="background-color: #050505 !important;">
                    <i class="bi bi-cpu-fill display-1 text-secondary opacity-25 mb-4 d-block"></i>
                    <h4 class="text-secondary fw-bold text-uppercase tracking-widest">Storage Empty</h4>
                    <p class="text-muted mx-auto mb-4" style="max-width: 400px;">
                        @(ViewBag.CloudStatus == "OFFLINE" ? "Your Cloud database is offline." : "Your Cloud storage is currently empty. Go to the dashboard to sync products.")
                    </p>

                    <div class="mt-4">
                        <a href="/Home/Privacy" class="btn btn-info px-5 fw-bold rounded-pill shadow">
                            <i class="bi bi-speedometer2 me-2"></i> OPEN DASHBOARD
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@* --- JavaScript for Cloud Sync --- *@
@section Scripts {
    <script>
        async function syncToCloud(productData, buttonElement) {
            const originalText = buttonElement.innerHTML;
            buttonElement.innerHTML = '<i class="bi bi-cloud-arrow-up-fill me-1"></i> SAVING TO CLOUD...';
            buttonElement.disabled = true;

            try {
                const response = await fetch('/api/ProductSync/sync-built-in', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(productData)
                });

                const result = await response.json();

                if (result.success) {
                    alert("✅ Success: " + result.message);
                    location.reload();
                } else {
                    alert("❌ Error: " + (result.message || result.error));
                }
            } catch (error) {
                console.error("Sync Error:", error);
                alert("❌ Critical Error: Could not reach the Cloud Server.");
            } finally {
                buttonElement.innerHTML = originalText;
                buttonElement.disabled = false;
            }
        }
    </script>
}
